{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "!/assets/**",
        "destination": "/index.html"
      },
      {
        "source": "!**/*.{png,jpg,jpeg,gif,webp,svg,pdf}",
        "destination": "/index.html"
      }
    ]
  }
}
